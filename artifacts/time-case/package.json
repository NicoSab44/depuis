    "android:build:signed:local": "eas build --platform android --profile production-signed-local",
    "android:preview:signed": "eas build --platform android --profile preview-signed",
    "android:submit": "eas submit --platform android --profile production",
    "android:keystore:generate": "eas credentials --platform android",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
