  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node scripts/build.js && node server/serve.js",
    "start": "expo start",
    "web": "expo export --platform web --output-dir dist && node server/serve.js",
    "build": "node scripts/build.js",
    "serve": "node server/serve.js",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
