{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-signed": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      }
    },
    "production-signed-local": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "local"
      }
    },
    "preview-signed": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
